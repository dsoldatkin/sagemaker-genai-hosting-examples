# Claude Code against the local LiteLLM gateway.
# Claude Code is Messages-native; LiteLLM must expose an Anthropic-compatible
# route for this to work in your installed version.

export CLAUDE_CODE_API_BASE_URL="http://127.0.0.1:4000"
export BASE_API_URL="http://127.0.0.1:4000"
export ANTHROPIC_BASE_URL="http://127.0.0.1:4000"
export _CLAUDE_CODE_ASSUME_FIRST_PARTY_BASE_URL="1"
export ANTHROPIC_API_KEY="${LITELLM_MASTER_KEY:-sk-local-litellm}"
export ANTHROPIC_MODEL="coding-default"
